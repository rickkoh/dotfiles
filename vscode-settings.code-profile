{"name": "vscode-settings", "settings": "{\"settings\": \"{\\n  \\\"vim.foldfix\\\": true,\\n  \\\"vim.vimrc.enable\\\": true,\\n  \\\"vim.normalModeKeyBindings\\\": [\\n    {\\n      \\\"before\\\": [\\n        \\\"u\\\"\\n      ],\\n      \\\"commands\\\": [\\n        \\\"undo\\\"\\n      ]\\n    },\\n    {\\n      \\\"before\\\": [\\n        \\\"c-r\\\"\\n      ],\\n      \\\"commands\\\": [\\n        \\\"redo\\\"\\n      ]\\n    },\\n    {\\n      \\\"before\\\": [\\n        \\\" \\\"\\n      ],\\n      \\\"after\\\": [\\n        \\\"/\\\"\\n      ]\\n    },\\n    {\\n      \\\"before\\\": [\\n        \\\"<C-h>\\\"\\n      ],\\n      \\\"after\\\": [\\n        \\\"<C-PageUp>\\\"\\n      ]\\n    },\\n    {\\n      \\\"before\\\": [\\n        \\\"<C-l>\\\"\\n      ],\\n      \\\"after\\\": [\\n        \\\"<C-PageDown>\\\"\\n      ]\\n    }\\n  ],\\n  \\\"vim.statusBarColorControl\\\": true,\\n  \\\"vim.statusBarColors.normal\\\": \\\"#3D8B3D\\\",\\n  \\\"vim.statusBarColors.visualline\\\": \\\"#775432\\\",\\n  \\\"vim.statusBarColors.commandlineinprogress\\\": \\\"#775432\\\",\\n  \\\"vim.statusBarColors.searchinprogressmode\\\": \\\"#775432\\\",\\n  \\\"vim.statusBarColors.easymotioninputmode\\\": \\\"#775432\\\",\\n  \\\"vim.statusBarColors.easymotionmode\\\": \\\"#775432\\\",\\n  \\\"vim.statusBarColors.surroundinputmode\\\": \\\"#775432\\\",\\n  \\\"vim.statusBarColors.insert\\\": \\\"#6B4E25\\\",\\n  \\\"vim.statusBarColors.replace\\\": \\\"#6B4E25\\\",\\n  \\\"vim.statusBarColors.visual\\\": \\\"#6B4E25\\\",\\n  \\\"vim.statusBarColors.visualblock\\\": \\\"#6B4E25\\\",\\n  \\\"workbench.colorCustomizations\\\": {\\n    \\\"statusBar.background\\\": \\\"#3D8B3D\\\",\\n    \\\"statusBar.noFolderBackground\\\": \\\"#3D8B3D\\\",\\n    \\\"statusBar.debuggingBackground\\\": \\\"#3D8B3D\\\"\\n  },\\n  \\\"workbench.colorTheme\\\": \\\"Popping and Locking Black Theme\\\",\\n  \\\"workbench.activityBar.location\\\": \\\"side\\\",\\n  \\\"workbench.tips.enabled\\\": 